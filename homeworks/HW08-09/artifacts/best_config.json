{
  "dataset": "EMNIST",
  "seed": 42,
  "model": {
    "input_dim": 784,
    "num_classes": 47,
    "hidden_dims": [
      256,
      128
    ],
    "dropout_p": 0.3,
    "use_batchnorm": false,
    "activation": "ReLU"
  },
  "training": {
    "optimizer": "Adam",
    "lr": 0.001,
    "weight_decay": 0,
    "batch_size": 64,
    "epochs": 25
  }
}